# =============================================================
# Lumanai Kava — environment variables
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is git-ignored (see .gitignore) so secrets stay put.
# =============================================================

# ── Shopify Storefront (for products, cart, checkout) ─────────
# Get these from: Shopify Admin → Settings → Apps and sales channels →
# Develop apps → create app → enable Storefront API → install → copy
# the Storefront API access token (public token, safe for the browser).
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
NEXT_PUBLIC_SHOPIFY_STOREFRONT_TOKEN=

# ── GoHighLevel (booking → CRM pipeline) ──────────────────────
# Booking form posts fire a webhook into your GHL workflow.
# Get the URL from: GHL → Automation → Workflows → new workflow →
# Add trigger "Inbound Webhook" → copy the Webhook URL.
GHL_BOOKING_WEBHOOK_URL=

# ── Twilio (SMS alert when a booking arrives) ─────────────────
# Optional — if set, the booking API will text you when a lead lands.
# Get from: console.twilio.com dashboard.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
TWILIO_ALERT_NUMBER=+17026260858

# ── Contact form ─────────────────────────────────────────────
# Where general contact messages get delivered.
CONTACT_EMAIL=lumanai.events@gmail.com
